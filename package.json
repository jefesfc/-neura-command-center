{
  "name": "neura-command-center",
  "version": "1.0.0",
  "description": "Neura Command Center — Social Studio & Post Generator",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "nodemon server.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm install --include=dev && npm run build",
    "install:all": "npm install && cd client && npm install",
    "postinstall": "echo 'skip playwright install'"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.52.7",
    "pg": "^8.12.0",
    "puppeteer": "^22.12.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
